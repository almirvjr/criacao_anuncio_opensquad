# Credenciais (so .env.example versiona)
.env
.env.*
!.env.example
.mcp.json

# Pasta de memoria do Claude
.claude/

# Respostas temporarias de API
api_response.json
put_result.json
run_result.json
update_response.json
last_exec.json
last_exec_full.json

# Payloads temporarios
*_payload.json
final_payload.json
minimal_payload.json
payload.json

# Backups de workflow gerados durante debug
workflow_backup_*.json
workflow_deactivate*.json
workflow_minimal_update.json
workflow_update_payload.json
workflow_original.json
workflow_updated.json
workflow.json

# Node/Python
node_modules/
__pycache__/
*.pyc
.venv/

# Outputs da squad (gerados pelo runner, podem ser grandes)
squads/*/output/
!squads/*/output/.gitkeep

# Build artifacts da squad (intermediários da investigação)
squads/*/_build/investigation/_raw/

# Memória de runs (pode ter dados sensíveis de produtos)
squads/*/_memory/runs.md

# Logs
_opensquad/logs/
*.log
